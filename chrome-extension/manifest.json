{
  "manifest_version": 3,
  "name": "VidGrab - One Click Downloader",
  "version": "4.0.0",
  "description": "Tải video không logo siêu tốc — TikTok, YouTube, Facebook, Instagram, Douyin, Spotify. Hỗ trợ kênh, playlist, ZIP, cắt video.",
  "permissions": [
    "activeTab",
    "tabs",
    "downloads",
    "storage",
    "scripting",
    "notifications",
    "contextMenus"
  ],
  "host_permissions": [
    "*://*.tiktok.com/*",
    "*://*.youtube.com/*",
    "*://*.facebook.com/*",
    "*://*.douyin.com/*",
    "*://*.iesdouyin.com/*",
    "*://*.instagram.com/*",
    "*://open.spotify.com/*",
    "https://dowload-video.mk.dev.matbao.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "VidGrab Downloader"
  },
  "icons": {
    "16": "assets/icon.png",
    "48": "assets/icon.png",
    "128": "assets/icon.png"
  },

  "content_scripts": [
    {
      "matches": ["*://*.douyin.com/*"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*.tiktok.com/*",
        "*://*.youtube.com/*",
        "*://*.facebook.com/*",
        "*://*.douyin.com/*",
        "*://*.instagram.com/*",
        "*://open.spotify.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
