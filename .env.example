# ── Supabase (bắt buộc) ──────────────────────────────────────────────
# Tạo project tại https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhbGci...

# ── Proxy (bắt buộc cho YouTube/TikTok) ─────────────────────────────
# IPRoyal residential proxy: https://iproyal.com
IPROYAL_PROXY=http://username:password@geo.iproyal.com:12321

# ── Telegram (tuỳ chọn — nhận thông báo lỗi) ────────────────────────
# Tạo bot: chat với @BotFather trên Telegram → /newbot
# Lấy chat_id: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── YouTube Cookies (khuyến nghị) ────────────────────────────────────
# Export cookies từ Chrome bằng extension "Get cookies.txt LOCALLY"
# Sau đó encode base64: base64 -w 0 cookies.txt
YOUTUBE_COOKIES_B64=

# ── TikTok / Facebook Cookies (tuỳ chọn) ────────────────────────────
TIKTOK_COOKIES_B64=
FACEBOOK_COOKIES_B64=

# ── Spotify (tuỳ chọn — tìm bài theo tên) ──────────────────────────
# Tạo app tại https://developer.spotify.com
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=

# ── Redis (mặc định, không cần đổi nếu dùng docker-compose) ─────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── App settings ─────────────────────────────────────────────────────
ENV=production
DOWNLOADS_MAX_GB=10
DAILY_QUOTA_PER_IP=50
VIDEO_INFO_CACHE_TTL=600
